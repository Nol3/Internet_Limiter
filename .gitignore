# ============================================
# Limitador - .gitignore
# ============================================

# --- PyInstaller / Build artifacts ---
build/
dist/
*.spec
!Limitador.spec.template

# --- Inno Setup output ---
installer_output/
*.iss.bak

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- IDEs / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Windows ---
Thumbs.db
Desktop.ini
*.lnk

# --- Local secrets / configs ---
*.local
.env
.env.local

# --- Logs ---
*.log
logs/

# --- Coverage ---
.coverage
htmlcov/
coverage.xml
